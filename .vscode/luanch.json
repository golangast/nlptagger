{
 
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch sql",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/nlptagger",
            "env": {},
             "args": [
                 "export ASSUME_NO_MOVING_GC_UNSAFE_RISK_IT_WITH=go1.21"
             ],
            "dlvLoadConfig": {
                "followPointers": true,
                "maxVariableRecurse": 1,
                "maxStringLen": 512,
                "maxArrayValues": 64,
                "maxStructFields": -1
            },
            "dlvFlags": [
                "--check-go-version=false"
            ]
        }
       
      
        
    ]
}